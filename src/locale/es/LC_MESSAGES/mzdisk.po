msgid "FAT Map"
msgstr "FAT mapa"

#: /home/chaky/projects/mzdisk/src/mzdisk/panels/panel_mrs_imgui.cpp:2050
msgid "MRS disk maintenance operations."
msgstr "Operaciónes de mantenimiento del disco MRS."

#: /home/chaky/projects/mzdisk/src/mzdisk/panels/panel_mrs_imgui.cpp:2057
msgid ""
"Reads all files into memory, formats file area, and writes files "
"sequentially without gaps. System area is preserved."
msgstr ""
"Lee todos los archivos en memoria, formatea el área de archivos y escribe "
"los archivos secuencialmente sin huecos. El área de sistema se conserva."

#: /home/chaky/projects/mzdisk/src/mzdisk/panels/panel_mrs_imgui.cpp:2117
msgid ""
"Reinitializes FAT and directory. System area (boot + MRS driver) is "
"preserved. All files become inaccessible."
msgstr ""
"Reinicializa FAT y directory. El área de sistema (boot + MRS driver) se "
"conserva. Todos los archivos se vuelven inaccesibles."

#: /home/chaky/projects/mzdisk/src/mzdisk/panels/panel_mrs_imgui.cpp:2135
msgid ""
"This will read all files into memory, format the file area, and write files "
"sequentially without gaps. System area (boot code, MRS driver) will be "
"preserved."
msgstr ""
"Esto leerá todos los archivos en memoria, formateará el área de archivos y "
"escribirá los archivos secuencialmente sin huecos. El área de sistema "
"(código de boot, MRS driver) se conservará."

#: /home/chaky/projects/mzdisk/src/mzdisk/panels/panel_mrs_imgui.cpp:2184
msgid ""
"This will reinitialize the FAT table and directory. All files will become "
"inaccessible. System area (boot code, MRS driver) will be preserved."
msgstr ""
"Esto reinicializará la tabla FAT y el directory. Todos los archivos se "
"volverán inaccesibles. El área de sistema (código de boot, MRS driver) se "
"conservará."

